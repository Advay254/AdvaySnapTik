# AdvaySnapTik — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

PORT=3000
SITE_URL=https://advaysnaptik.onrender.com

# API keys — generate with: openssl rand -hex 32
OWNER_API_KEY=replace_with_strong_random_key
RAPIDAPI_SECRET=replace_after_rapidapi_listing

# Ad monetization (all optional — leave blank if unused)
AD_CDN_URL=
AD_SMARTLINK_URL=
AD_BANNER_URL=
AD_POPUNDER_URL=
